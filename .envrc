use flake

# `use flake` watches flake.nix/flake.lock; also reload when the imported
# modules that define the shell and the out-links change.
watch_file flake.lock
watch_file nix/devshells.nix
watch_file nix/agent-set.nix
watch_file nix/agent-setting.nix

nix build .#agent-set --out-link .claude/skills/agent
nix build .#agent-setting --out-link .setting
